#PD:
#: prettyprint4(root, level, count)
#:
#:    |Start Column
#:    |-----------------------------------------
#:    |0:node("decls")
#:    |   1:node("package")
#:    |      1:node("lnkfile")
#:    |         1:parser
#:    |   2:node("class")
#:    |      1:DatabaseInfo
#:    |      2:node("supers")
#:    |      3:node("cparmlist")
#:    |         1:node("carg")
#:    |            1:node("priv")
#:    |            2:node("arg")
#:    |               1:name
#:    |         2:node("carg")
#:    |            1:node("priv")
#:    |            2:node("arg")
#:    |               1:directory
#:    |      4:node("semicolon")
#:
procedure prettyprint4(root, level, count)
   local i, j, e

   /level := 0
   /count := 0
   i := ::repl(" ", level * 3) || count || ":"
   if /root then {
      ::write(i, "EmptyNode")
   } else if ::type(root) == "treenode" then {
      ::write(i, "node(\"", root.label, "\"", (\root.description & " : description exists : " || ximage(root.description)) | "", ")")
      j := 1
      every e := !root.children do  {
         prettyprint4(e, level + 1, j)
         j +:= 1
      }
   } else if ::type(root) == "token" then {
      ::write(i, root.s)
   } else
      ::write(i, ::image(root))
end

#PD:
#: prettyprint5(root, level, count)
#:
#:    |Start Column
#:    |-----------------------------------------
#:    |0:node("decls"
#:    |   1:node("package"
#:    |      1:node("lnkfile"
#:    |         1:parser
#:    |   2:node("class"
#:    |      1:DatabaseInfo
#:    |      2:node("supers"
#:    |      3:node("cparmlist"
#:    |         1:node("carg"
#:    |            1:node("priv"
#:    |            2:node("arg"
#:    |               1:name
#:    |         2:node("carg"
#:    |            1:node("priv"
#:    |            2:node("arg"
#:    |               1:directory
#:    |      4:node("semicolon"
#:
procedure prettyprint5(root, level, count)
   local i, j, e

   /level := 0
   /count := 0
   i := ::repl(" ", level * 3) || count || ":"
   if /root then {
      ::write(i, "EmptyNode")
   } else if ::type(root) == "treenode" then {
      ::write(i, "node(\"", root.label, "\"", (\root.description & " : description exists : " || ximage(root.description)) | "")
      j := 1
      every e := !root.children do  {
         prettyprint5(e, level + 1, j)
         j +:= 1
      }
   } else if ::type(root) == "token" then {
      ::write(i, root.s)
   } else
      ::write(i, ::image(root))
end

#PD:
#: prettyprint6(root, level, count, prefix1l, prefixfl, branch)
#:
#:    |Start Column
#:    |-----------------------------------------
#:    |--1:node("decls"
#:    |   +--1:node("package"
#:    |   |   +--1:node("lnkfile"
#:    |   |       +--1:parser
#:    |   +--2:node("class"
#:    |       +--1:DatabaseInfo
#:    |       +--2:node("supers"
#:    |       +--3:node("cparmlist"
#:    |       |   +--1:node("carg"
#:    |       |   |   +--1:node("priv"
#:    |       |   |   +--2:node("arg"
#:    |       |   |       +--1:name
#:    |       |   +--2:node("carg"
#:    |       |       +--1:node("priv"
#:    |       |       +--2:node("arg"
#:    |       |           +--1:directory
#:    |       +--4:node("semicolon"
#:
procedure prettyprint6(root, level, count, prefix1l, prefixfl, branch)
   local i, j, e

   /level := 0
   /count := 1
   /prefix1l := ""
   /prefixfl := "   "
   /branch := ""
   i := prefix1l || branch || ::right(count, 3, "-") || ":"
   if /root then {
      ::write(i, "EmptyNode")
   } else if ::type(root) == "treenode" then {
      ::write(i, "node(\"", root.label, "\"", (\root.description & " : description exists : " || ximage(root.description)) | "")
      prefix1l := prefixfl
      every e := root.children[j := 1 to *root.children - 1] do  {
         prettyprint6(e, level + 1, j, prefix1l, prefixfl || "|   ", "+")
      }
      prettyprint6(root.children[*root.children], level + 1, *root.children, prefix1l, prefixfl || "    ", "+")
   } else if ::type(root) == "token" then {
      ::write(i, root.s)
   } else
      ::write(i, ::image(root))
end
