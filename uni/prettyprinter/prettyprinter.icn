#:    |       |       +--1:node("priv")
#:    |       |       +--2:node("arg")
#:    |       |           +--1:directory
#:    |       +--4:node("semicolon")
#:
procedure prettyprint3(root, level, count, prefix1l, prefixfl, branch)
   local i, j, e

   /level := 0
   /count := 1
   /prefix1l := ""
   /prefixfl := "   "
   /branch := ""
   i := prefix1l || branch || ::right(count, 3, "-") || ":"
   if /root then {
      ::write(i, "EmptyNode")
   } else if ::type(root) == "treenode" then {
      ::write(i, "node(\"", root.label, "\"", (\root.description & " : description exists : " || ximage(root.description)) | "", ")")
      prefix1l := prefixfl
