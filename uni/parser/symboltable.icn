    defined_procedures["where"]         := builtin_entry(NormalProcedure, "f")
    defined_procedures["write"]         := builtin_entry(NormalProcedure, ["s", "f"], "...")
    defined_procedures["writes"]        := builtin_entry(NormalProcedure, ["s", "f"], "...")
