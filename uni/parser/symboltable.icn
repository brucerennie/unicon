import ErrorSystem

global  current_file,                   #GD: table of the current declarations found in the current file
                                        #:   being processed, keyed by variable names,
                                        #:   this is used to pass around all the global values
                                        #:   that are needed by each of the different types of
                                        #:   global structures as in procedures, classes, records,
                                        #:   methods, imports and links. The use of a table to hold
                                        #:   the current global values means that any future changes
                                        #:   do not require an actual global variable to be defined,
                                        #:   it is only necessary to create the new key value to
                                        #:   represent the new current value variable
                                        #:  ✓
        current_declaration,            #GD: table of the current information that has been collected
                                        #:   during the parsing of the current declaration. This information
                                        #:   will be added to the table current_file when the declaration is
                                        #:   being finalised.
                                        #:
        this_is_generator,              #GD: this is the flag to indicate that the current
                                        #:   procedure or method is a generator, this is
                                        #:   determined if "suspend" is found in the body
                                        #:   of the procedure or method. This information
                                        #:   will be used in determining if a "while" has
                                        #:   an inappropriate expression as the test expression,
                                        #:   this will be &null for all procedures and methods
                                        #:   that are not found to be generators.
                                        #:  ✓
        symbol_table                    #GD: table of tables/lists/strings, keys
                                        #:   being the classifications of the
                                        #:   different types of things being
                                        #:   stored in the symbol table, this will hold all of the
                                        #:   relevant information for all files that are being
                                        #:   processed in this particular run of the compiler
                                        #:  ✓

procedure initialise_symbol_table()

    current_file                := ::table()    #GV: creating the table to hold the information collected
                                                #:   during the parsing of the current file. The keys will
                                                #:   be related to each of the global classifications for
                                                #:   the possible declarations that can occur within any file
                                                #:
    current_declaration         := ::table()    #GV: creating the table to hold the specific information that
                                                #:   will be collected for each kind of declaration. The keys
                                                #:   will be specific to each of the diffferent declarations
                                                #:   and are entered during the parsing processed.
                                                #:   Declarations are "global", "record", "procedure" or "class".
                                                #:   "method" belongs to a "class" declaration.
                                                #:   "package", "link", "import" and "invocable" are treated and
                                                #:   recorded in a different manner. Both "link" and "import"
                                                #:   will add information to the symbol table but will get the
                                                #:   relevant information from external sources. The "$include"
                                                #:   directive simply loads additional source files to the parsing
                                                #:   process.
                                                #:
    current_file["procedure_name"]   := &null   #GK: name of current procedure or method being defined
                                                #:  ✓
    current_file["class_name"]       := &null   #GK: name of the current class being defined, if it is
                                                #:   null, then we are not in a class definition.
                                                #:  ✓
    current_file["record_name"]      := &null   #GK: name of the current record being defined
                                                #:  ✓
    current_file["class"]            := &null   #GK: table of tables/list/string for
                                                #:   current class being defined. Keys are as defined below.
                                                #:  ✓
    current_file["methods"]          := &null   #GV: table of lists of method variables,
                                                #:   keyed by method name and specifically
                                                #:   for the current class being defined. Used to
                                                #:   determine the uniqueness of the method names
                                                #:  ✓
    current_file["supers"]           := &null   #GK: list of superclass names used in the current class in
                                                #:   order of declaration. a superclass will only appear once
                                                #:   in the superclass list, eve though it is allowed to occur
                                                #:   multiple times due to inheritance
                                                #:  ✓
    current_file["supers_set"]       := &null   #GK: set of superclass names used in the current class, used
                                                #:   to ensure that a superclass only appears once in the
                                                #:   superclass list
                                                #:  ✓
    current_file["class_locals"]     := &null   #GK: list of the current class local variables in order
                                                #:   of declaration of locals. Includes all class parameters
                                                #:   as well as any locally defined class local variables.
                                                #:  ✓
    current_file["class_locals_set"] := &null   #GK: set of the current class local variables used for
                                                #:   determining the uniqueness of the class local
                                                #:  ✓
    current_file["package"]          := ""      #GK: holds name of the current package, until a "package"
                                                #:   directive if found, it will contain the generic
                                                #:   package name ""
                                                #:  ✓
    current_file["package_references"]:= ::table()
                                                #GK: holds the package import details as obtained from the
                                                #:   uniclass databases containing that package. The key is
                                                #:   the package name.
                                                #:  ✓
    current_file["package_imports"]  := ::set([])
                                                #GK: a set of the packages that have been imported into
                                                #:   this file
                                                #:  ✓
    current_file["link_file"]        := &null
    current_file["parameters"]       := &null   #GK: list of the current parameter variables in
                                                #:   order of declaration
                                                #:  ✓
    current_file["parameters_set"]   := &null   #GK: this is a set of the current parameter variables so
                                                #:   far found in the definition of a method, procedures and
                                                #:   classes.
                                                #:  ✓
    current_file["variable_set"]     := &null   #GK: this is a set of the current variables so far found
                                                #:   in the definition of a method or procedure. It is used
                                                #:   to test uniqueness and covers the four areas that can
                                                #:   contribute to the list of variables. These four areas
                                                #:   are parameters, local variables, static variables and
                                                #:   list comprehension variables. List comprehension variables
                                                #:   are the only type of system generated variables at this point.
                                                #:  ✓
    current_file["locals"]           := &null   #GK: list of the current local variables in
                                                #:   order of declaration. As each "local" declaration is processed,
                                                #:   the associated variables are added to this list.
                                                #:  ✓
    current_file["statics"]          := &null   #GK: list of the current static variables in
                                                #:   order of declaration. As each "static" declaration is processed,
                                                #:   the associated variables are added to this list.
                                                #:  ✓
    current_file["listcomp"]         := &null   #GK: list of the current list comprehension variables in
                                                #:   order of use. As each list comprehension is processed,
                                                #:   the associated variables are added to this list.
                                                #:  ✓
    current_file["unknowns"]         := ::set([])
                                                #GK: set of variable names used in the current procedure or method,
                                                #:   these are variables that have not been declared as
                                                #:   parameters nor locals nor statics. This will not include any
                                                #:   of the system defined variable that arise from list comprehensions.
                                                #:   As global variables, procedures and records are in essence variables,
                                                #:   any such variables will be found in this set. The set will later
                                                #:   be compared with the global variables, procedures and records.
                                                #:  ✓
    current_file["variable_list"]    := &null   #GK: list of currently processed variables found in the current
                                                #:   "local" or "static" declaration being processed.
                                                #:   this list will be amalgamated to the specific
                                                #:   current_file["locals"], current_file["statics"] or
                                                #:   current_file["class_locals"] as required
                                                #:  ✓
    current_file["identifiers"]      := []      #GK: list of current identifiers in order of declaration,
                                                #:   these identifiers include global variables, record names,
                                                #:   class names and procedure names, excluding in-built
                                                #:   function names as these are allowed to be redefined. Only
                                                #:   global variables are allowed to be declared multiple times.
                                                #:   All other names must be unique.
                                                #:  ✓
    current_file["identifiers_set"] := ::set([])
                                                #GK: set of current identifiers used for determining
                                                #:   uniqueness of identifiers
                                                #:  ✓
    current_file["globals_set"]     := ::set([])
                                                #GK: set of all globally defined names, this includes
                                                #:   global variables, procedures, records, classes, this
                                                #:   set is used to ensure that redefinition of (procedures,
                                                #:   classes and variables) by other (procedures, classes
                                                #:   and variables) does not happen
                                                #:  ✓
    this_is_generator               := &null    #    Initialising the global variable to the standard default
                                                #:   value of &null. This will only change when a "suspend" is
                                                #:   encountered during the parsing of a method or procedure.

    symbol_table                    := ::table()
    symbol_table["classes"]         := ::table()
                                                #GK: table of tables of the class definitions,
                                                #:   keyed by the class name. This is used for
                                                #:   determining the uniqueness of the class name
                                                #:  ✓
    symbol_table["procedures"]      := ::table()
                                                #GK: table of tables holding information collected about each
                                                #:   procedure
                                                #:  ✓
    symbol_table["built_ins"]       := insert_builtins()
                                                #GK: table of tables which holds all the information that
                                                #:   we have about each of the built-in functions.
                                                #:  ✓
    symbol_table["unknowns"]        := ::table()
                                                #GK: table of sets of names used in the procedures
                                                #:   or methods being defined, which have not been
                                                #:   defined as either local or static. These will need to be
                                                #:   resolved against the globals defined within the linked program.
                                                #:   The key is the name of the procedure or method (including class name)
                                                #:   being defined
    symbol_table["globals"]         := []       #GK: list of current global identifiers, declared as "global"
                                                #:  ✓
    symbol_table["records"]         := ::table()
                                                #GK: table of lists of defined fields
                                                #:   for records. The key is the name of
                                                #:   the record being defined. This is used for testing
                                                #:   the uniqueness of the record names
                                                #:  ✓
    symbol_table["package"]         := ""
    symbol_table["links"]           := ::table()
                                                #GK: table holding the information from the linked file,
                                                #:   keyed by link file name. This will hold relevant information
                                                #:   about the linked file, each of the declarations found in the
                                                #:   linked file will be added to the various tables for procedures,
                                                #:   records and global declarations. Should not link files that have
                                                #:   class information as this will be brought in by the "import"
                                                #:   declarations.
                                                #:  ✓
    symbol_table["imports"]         := ::table()
                                                #GK: table holding all the import information, keyed by import name.
                                                #:   there is some crossover with the package references and needs to
                                                #:   tidied up.
                                                #:  ✓
    symbol_table["invocables"]      := []       #GK: list of invocable procedure found in the "invocable" declaration
                                                #:  ✓
    ErrorSystem()
end

$define Generator           1
$define NormalProcedure     &null
$define NoParam             &null

#PD:
#: insert_builtins(defined_procedures) - insert each of the standard functions
#: provided by the iconx runtime. Some of these will not be applicable to the
#: iconc compiler and will require checking if the iconc compiler is being used.
#: Code will need to be inserted to ensure that the relevant functions are
#: removed from the set of functions.
#:
#:@global current_file["globals_set"]
#:
#:@returns              the table into which we shall be placing the
#:@                     details for the runtime functions. the parameter name
#:@                     deliberately overides the global variable of the same
#:@                     name
#:
procedure insert_builtins()
    local   defined_procedures          #LV: local table which will have an entry
                                        #:   for each standard Unicon function

    defined_procedures := ::table()
    #
    #: the meaning for each of the strings is related to its type and this is used
    #: instead of the parameter names.
    #
    #   Value           Meaning
    #
    #   "n"             number                  - or values convertible to real or integer
    #   "r"             real                    - or values convertible to real
    #   "i"             integer                 - or values convetible to integer
    #   "c"             cset                    - or values convertible to cset
    #   "l"             list                    - of any
    #   "tb"            table
    #   "st"            set
    #   "s"             string                  - or values convertible to string
    #   "flg"           flag
    #   "x"             any
    #   "th"            thread
    #   "f"             file
    #   "rec"           record
    #   "cl"            class
    #   "obj"           object
    #   "v"             variable
    #   "cv"            condition variable
    #   "w"             window
    #   "pr"            procedure or method
    #   "p"             pattern
    #   "ce"            co-expression
    #   "..."           one or more strings     - or values convertable to strings
    #   "D"             database
    #   "M"             POP mailbox
    #   "---"           zero or more values
    #   ",,,"           zero or more integers   - or values convertible to integer
    #   "n,,,"          one or more numeric     - or values convertible to real or integer
    #
    #: the first parameter of builtin_entry is explicitly set to &null when the
    #: builtin function is not a generator, otherwise it is set to 1 when it is
    #: an inherent generator. See the above definitions of NormalProcedure and Generator above.
    #: if any additional functions are installed into the runtime, add them to the assignments
    #: below.
    #:
    defined_procedures["abs"]           := builtin_entry(NormalProcedure, "n")
    defined_procedures["acos"]          := builtin_entry(NormalProcedure, "r")
    defined_procedures["any"]           := builtin_entry(NormalProcedure, "c", "s", "i", "i")
    defined_procedures["args"]          := builtin_entry(NormalProcedure, "x", "i")
    defined_procedures["asin"]          := builtin_entry(NormalProcedure, "r")
    defined_procedures["atan"]          := builtin_entry(NormalProcedure, "r", "r")
    defined_procedures["atanh"]         := builtin_entry(NormalProcedure, "r")
    defined_procedures["bal"]           := builtin_entry(Generator,       "c", "c", "c", "s", "i", "i")
    defined_procedures["center"]        := builtin_entry(NormalProcedure, "s", "i", "s")
    defined_procedures["channel"]       := builtin_entry(NormalProcedure, "th")
    defined_procedures["char"]          := builtin_entry(NormalProcedure, "i")
    defined_procedures["chdir"]         := builtin_entry(NormalProcedure, "s")
    defined_procedures["chmod"]         := builtin_entry(NormalProcedure, ["f", "s"], "s")
    defined_procedures["classname"]     := builtin_entry(NormalProcedure, "rec")
    defined_procedures["close"]         := builtin_entry(NormalProcedure, "f")
    defined_procedures["cofail"]        := builtin_entry(NormalProcedure, "ce")
    defined_procedures["collect"]       := builtin_entry(NormalProcedure, "i", "i")
    defined_procedures["condvar"]       := builtin_entry(NormalProcedure, )
    defined_procedures["constructor"]   := builtin_entry(NormalProcedure, "s", "...")
    defined_procedures["copy"]          := builtin_entry(NormalProcedure, "x")
    defined_procedures["cos"]           := builtin_entry(NormalProcedure, "r")
    defined_procedures["cset"]          := builtin_entry(NormalProcedure, "x")
    defined_procedures["ctime"]         := builtin_entry(NormalProcedure, "i")
    defined_procedures["dbcolumns"]     := builtin_entry(NormalProcedure, "D", "s")
    defined_procedures["dbdriver"]      := builtin_entry(NormalProcedure, "D")
    defined_procedures["dblimits"]      := builtin_entry(NormalProcedure, "D")
    defined_procedures["dbproduct"]     := builtin_entry(NormalProcedure, "D")
    defined_procedures["dbtables"]      := builtin_entry(NormalProcedure, "D")
    defined_procedures["delay"]         := builtin_entry(NormalProcedure, "i")
    defined_procedures["delete"]        := builtin_entry(NormalProcedure, "x", "x", "---")
    defined_procedures["detab"]         := builtin_entry(NormalProcedure, "s", "i", ",,,")
    defined_procedures["display"]       := builtin_entry(NormalProcedure, "i", "f", "ce")
    defined_procedures["dtor"]          := builtin_entry(NormalProcedure, "r")
    defined_procedures["entabs"]        := builtin_entry(NormalProcedure, "s", "i", ",,,")
    defined_procedures["errorclear"]    := builtin_entry(NormalProcedure, )
    defined_procedures["eventmask"]     := builtin_entry(NormalProcedure, "ce", "c")
    defined_procedures["EvGet"]         := builtin_entry(NormalProcedure, "c", "flg")       ### Need more details here
    defined_procedures["EvSend"]        := builtin_entry(NormalProcedure, "i", "x", "ce")   ### Need more details here
    defined_procedures["exit"]          := builtin_entry(NormalProcedure, "i")
    defined_procedures["exp"]           := builtin_entry(NormalProcedure, ["r", "i"])
    defined_procedures["fetch"]         := builtin_entry(NormalProcedure, "D", "s")
    defined_procedures["fieldnames"]    := builtin_entry(Generator,       "rec")
    defined_procedures["find"]          := builtin_entry(Generator,       "s", "s", "i", "i")
    defined_procedures["flock"]         := builtin_entry(NormalProcedure, "f", "s")
    defined_procedures["flush"]         := builtin_entry(NormalProcedure, "f")
    defined_procedures["functiom"]      := builtin_entry(Generator,       )
    defined_procedures["get"]           := builtin_entry(NormalProcedure, "l", "i")
    defined_procedures["getch"]         := builtin_entry(NormalProcedure, )
    defined_procedures["getche"]        := builtin_entry(NormalProcedure, )
    defined_procedures["getenv"]        := builtin_entry(NormalProcedure, "s")
    defined_procedures["gettimeofday"]  := builtin_entry(NormalProcedure, )
    defined_procedures["globalnames"]   := builtin_entry(Generator,       "ce")
    defined_procedures["gtime"]         := builtin_entry(NormalProcedure, "i")
    defined_procedures["iand"]          := builtin_entry(NormalProcedure, "i", "i")
    defined_procedures["icom"]          := builtin_entry(NormalProcedure, "i")
    defined_procedures["image"]         := builtin_entry(NormalProcedure, "x")
    defined_procedures["insert"]        := builtin_entry(NormalProcedure, ["st", "tb", "l", "D"], "x", "x")
    defined_procedures["integer"]       := builtin_entry(NormalProcedure, "x")
    defined_procedures["ior"]           := builtin_entry(NormalProcedure, "i", "i")
    defined_procedures["ishift"]        := builtin_entry(NormalProcedure, "i", "i")
    defined_procedures["istate"]        := builtin_entry(NormalProcedure, "ce", "s")
    defined_procedures["ixor"]          := builtin_entry(NormalProcedure, "i", "i")
    defined_procedures["kbhit"]         := builtin_entry(NormalProcedure, )
    defined_procedures["key"]           := builtin_entry(Generator,       ["tb", "l", "rec"])
    defined_procedures["keyword"]       := builtin_entry(Generator,       "s", "ce", "i")
    defined_procedures["left"]          := builtin_entry(NormalProcedure, "s", "i", "s")
    defined_procedures["list"]          := builtin_entry(NormalProcedure, "i", "x")
    defined_procedures["load"]          := builtin_entry(NormalProcedure, "s", "l", "f", "f", "f", "i", "i", "i")
    defined_procedures["loadfunc"]      := builtin_entry(NormalProcedure, "s", "s")
    defined_procedures["localnames"]    := builtin_entry(Generator,       "ce", "i")
    defined_procedures["lock"]          := builtin_entry(NormalProcedure, "x", "x")
    defined_procedures["log"]           := builtin_entry(NormalProcedure, ["r", "i"], ["r", "i"])
    defined_procedures["many"]          := builtin_entry(NormalProcedure, "c", "s", "i", "i")
    defined_procedures["map"]           := builtin_entry(NormalProcedure, "s", "s", "s")
    defined_procedures["match"]         := builtin_entry(NormalProcedure, "s", "s", "i", "i")
    defined_procedures["max"]           := builtin_entry(NormalProcedure, "n,,,")
    defined_procedures["member"]        := builtin_entry(NormalProcedure, ["st", "c", "tb", "l"], "x", "---")
    defined_procedures["membernames"]   := builtin_entry(NormalProcedure, ["s", "obj", "cl"])
    defined_procedures["methods"]       := builtin_entry(NormalProcedure, ["s", "obj", "cl"])
    defined_procedures["min"]           := builtin_entry(NormalProcedure, "n,,,")
    defined_procedures["mkdir"]         := builtin_entry(NormalProcedure, "s", ["s", "i"])      ### needs testing reals
    defined_procedures["move"]          := builtin_entry(NormalProcedure, "i")
    defined_procedures["mutex"]         := builtin_entry(NormalProcedure, "x", "x")
    defined_procedures["name"]          := builtin_entry(NormalProcedure, "v", "ce")
    defined_procedures["numeric"]       := builtin_entry(NormalProcedure, "x")
    defined_procedures["open"]          := builtin_entry(NormalProcedure, "s", "s", "...")
    defined_procedures["opmask"]        := builtin_entry(NormalProcedure, "ce", "c")
    defined_procedures["oprec"]         := builtin_entry(NormalProcedure, "obj")
    defined_procedures["ord"]           := builtin_entry(NormalProcedure, "s")
    defined_procedures["paramnames"]    := builtin_entry(NormalProcedure, "ce", "i")
    defined_procedures["parent"]        := builtin_entry(NormalProcedure, "ce")
    defined_procedures["pipe"]          := builtin_entry(NormalProcedure, )
    defined_procedures["pop"]           := builtin_entry(NormalProcedure, ["l", "M"])
    defined_procedures["proc"]          := builtin_entry(NormalProcedure, ["s", "ce"], "i", "ce")
    defined_procedures["pull"]          := builtin_entry(NormalProcedure, "l", "i")
    defined_procedures["push"]          := builtin_entry(NormalProcedure, "l", "---")
