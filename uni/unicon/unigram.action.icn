procedure expr11_action_17(items[])
    local   result,                     #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action
            fakeThreadIdent,
            fakeCreate,
            fakeLParen,
            fakeRParen

    fakeThreadIdent := Clone1stToken(items[1])
    fakeThreadIdent.tok := IDENT
    fakeCreate := Clone1stToken(items[1])
    fakeCreate.tok := CREATE
    fakeCreate.s := "create"
    fakeThreadIdent.s := "spawn"
    fakeLParen := Clone1stToken(items[1])
    fakeLParen.tok := LPAREN
    fakeLParen.s := "("
    fakeRParen := Clone1stToken(items[1])
    fakeRParen.tok := RPAREN
    fakeRParen.s := ")"

    result := SimpleInvocation(fakeThreadIdent,fakeLParen,
                           node("create", fakeCreate, items[2]),
                           fakeRParen)
    return result
end

