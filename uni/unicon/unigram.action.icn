procedure exprlist_action_2(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    if type(items[1])=="treenode" & (items[1].label=="elst1") then {
        result := items[1]; put(result.children, items[2], items[3])
        }
    else
        result := node("elst1", items[1], items[2], items[3])
    return result
end

