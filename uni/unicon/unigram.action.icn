#
# Semantic actions related to nonterminal "while"
#
procedure while_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := node("While0", items[1], items[2])
    return result
end

procedure while_action_2(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    # warn if a while loop should be an every.
    # should generalize; compute a semantic attribute and
    # warn if a while loop control expression is a generator.
    # but for now, only complain about the most obvious case
    if type(items[2]) == "treenode" & items[2].label === "assign" &
       *items[2].children = 3 & type(items[2].children[3]) == "treenode" &
       items[2].children[3].label == "to" & *(items[2].children[3].children) = 3 &
             (type(items[2].children[3].children[1]) ===
              type(items[2].children[3].children[3]) === "token") &
             (items[2].children[3].children[1].tok =
              items[2].children[3].children[3].tok = INTLIT) &
             items[2].children[3].children[1].s <= items[2].children[3].children[3].s
    then {
        warning("infinite loop; use \"every\" to loop on generator results",
                items[1].line, items[1].filename, items[1].s
                )
        }
    result := node("While1", items[1], items[2], items[3], items[4])
    return result
end

