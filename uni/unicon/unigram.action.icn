#
# Semantic actions related to nonterminal "cl"
#
procedure cl_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := class_from_parts(items[1], items[3], items[4], items[6])
    return result
end

#
# Semantic actions related to nonterminal "classhead"
#
procedure classhead_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := Class()
    result.tag := items[1]
    result.unmangled_name := items[2].s
    result.name := package_mangled_symbol(items[2].s)
    if proc(result.name, 0) then
        warning("Warning: class "|| result.name ||" overrides the built-in function")
    if \ (foobar := classes.lookup(result.name)) then {
        yyerror("redeclaration of class " || result.name)
        }
    else
        classes.insert(result, result.name)

    result.supers_node := items[3]
    result.fields := items[5]
    result.lptoken := items[4]
    result.rptoken := items[6]
    return result
end

