end


#
# Semantic actions related to nonterminal "brackchars"
#
procedure brackchars_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := items[1]
    return result
end

procedure brackchars_action_2(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := node("brackchars", items[1], items[2], items[3])
    return result
end

procedure brackchars_action_3(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    if type(items[1]) == "treenode" then {
        c1 := csetify(items[1])
        }
    if type(items[2]) == "treenode" then c2 := csetify(items[2])

    result := copy(items[1])
    while type(result) == "treenode" do {
        result := copy(result.children[1])
        result.s := c1
        }
    if type(result) ~== "token" then stop("regex type ", image(result))

    if type(items[2]) == "treenode" then result.s ||:= c2
    else result.s ||:=items[2].s
    return result
end


#
# Semantic actions related to nonterminal "brackchars2"
#
procedure brackchars2_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := items[1]
    return result
end

procedure brackchars2_action_2(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := items[1]
    return result
end

procedure brackchars2_action_3(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := items[1]
    return result
end

procedure brackchars2_action_4(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := items[1]
    return result
end

procedure brackchars2_action_5(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := items[2]
    result.column := items[1].column
    case result.s[1] of {
        "b"|"d"|"e"|"f"|"l"|"n"|"r"|"t"|"v": result.s[1] := "\\" || result.s[1]
        default: stop("unrecognized escape char \\", result.s[1])
        }
    return result
end

procedure brackchars2_action_6(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    #escaped octal?
    result := items[2]
    result.column := items[1].column
    case result.s[1] of {
        "0"|"1"|"2"|"3"|"4"|"5"|"6"|"7": result.s[1] := "\\" || result.s[1]
        default: stop("non-octal numeric escape char \\", result.s[1])
        }
    return result
end


