procedure neregex3_action_11(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := node("acset", items[1], items[2], items[3])
    if type(items[2]) == "token" then {
        if not ((items[1].line == items[2].line) &
                (items[1].column + 1 == items[2].column)) then {
            # [ is nonadjacent, add space
            items[2].s := " " || items[2].s
            }
        }
     else write("[ followed by ", type(items[2]), " so not checking for space")
    return result
end

procedure neregex3_action_12(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := node("notany", items[1], items[2], items[3], items[4])
    return result
end

