#
# Semantic actions related to nonterminal "package"
#
procedure package_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    if \thePackage then {
        if not (thePackage.name == items[2].s) then {
            yyerror(yyfilename || " cannot be in both package "|| thePackage.name ||
                                  " and package " || items[2].s)
            result := &null
            }
        else { # this branch allowed for -C / iconc
            thePackage.insertfname(yyfilename)
            thePackage.add_imported()
            }
        }
    else {
        result := node("package", items[1], items[2]);
        thePackage := Package(items[2].s)
        thePackage.insertfname(yyfilename)
        thePackage.add_imported()
        }
    return result
end

