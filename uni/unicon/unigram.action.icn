#
# Unicon unigram.y code include/link file for semantic action section
#
#
# Updated: Bruce Rennie - convert all standard Unicon functions to have "::" prefix
# Date:    2020-12-28
#

record treenode(label, children)

procedure node(label, children[])
   return treenode(label, children)
end

$include "ytab_h.icn"

#
# Procedure to generate unique temporary variable name
#
procedure TempVar()
    static  counter,                    #LV: holds the current counter value to
                                        #:   be used for the next temporary variable
                                        #:   name to be generated
            prefix                      #LV: the prefix to be used for the temporary
                                        #:   variable name
    local   tmpname                     #LV: the temporary name to be returned

    initial {
        counter := 1
        prefix := "__"
    }
    tmpname := prefix || counter
    counter +:= 1
    return tmpname
end

#
# Semantic actions related to nonterminal "program"
#
procedure program_action_1(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := Progend(items[1])
    return result
end

procedure program_action_2(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    push(\items[2].children, items[1])
    result := items[2]
    return result
end

