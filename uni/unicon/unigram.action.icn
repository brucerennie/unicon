    return result
end

procedure neregex2_action_5(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    if items[3].s < 0 then {
        yyerror("regex occurrences may not be negative")
        result := node("error")
        }
    else if items[3].s = 0 then {
        yyerror("regex occurrences may not be zero yet")
        result := node("error")
        }
    else if items[3].s = 1 then result := items[1]
    else { # normal case, positive number of repeats of items[1]
        result := items[1]
        every i := 2 to items[3].s do {
            result := node("regexconcat", result, items[1])
            }
        }
    return result
end


