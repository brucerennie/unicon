procedure initiallysection_action_2(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := Method( , , , , , items[1], "initially", &null, "method", "(", ")")
    result.locals := items[3]
    result.initl := items[4]
    result.procbody := items[5]
    return result
end

procedure initiallysection_action_3(items[])
    local   result                      #LV: this is the result of the semantic
                                        #:   action that will be returned to the
                                        #:   parsing action

    result := Method( , , , , , items[1], "initially", items[3], "method", "(", ")")
    result.locals := items[6]
    result.initl := items[7]
    result.procbody := items[8]
    return result
end

